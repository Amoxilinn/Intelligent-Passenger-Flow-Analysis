
{
	"bsonType": "object",
	"required": ["phone", "password"],
	"permission": {
		"read": true,
		"create": true,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "ID，系统自动生成"
		},
		"phone": {
			"bsonType": "string",
			"description": "手机号",
			"title": "手机号",
			"pattern": "^1[3-9]\\d{9}$",
			"errorMessage": {
				"pattern": "请输入正确的手机号"
			}
		},
		"password": {
			"bsonType": "string",
			"description": "密码",
			"title": "密码",
			"minLength": 6,
			"errorMessage": {
				"minLength": "密码长度不能少于6位"
			}
		},
		"createdAt": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"autoValue": {
				"$date": "now"
			}
		}
	}
}